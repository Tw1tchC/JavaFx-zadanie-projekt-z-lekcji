<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650" prefWidth="700"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="sample.Controller">

    <children>

        <VBox spacing="12" layoutX="150" layoutY="30" styleClass="card">

            <Label text="Formularz rejestracyjny" styleClass="title"/>

            <TextField fx:id="nameField" promptText="Imię"/>
            <TextField fx:id="emailField" promptText="Email"/>
            <TextField fx:id="postalField" promptText="Kod pocztowy (XX-XXX)"/>
            <PasswordField fx:id="passwordField" promptText="Hasło"/>

            <HBox spacing="15">
                <RadioButton fx:id="maleRadio" text="Mężczyzna"/>
                <RadioButton fx:id="femaleRadio" text="Kobieta"/>
            </HBox>

            <HBox spacing="15">
                <CheckBox fx:id="sportCheck" text="Sport"/>
                <CheckBox fx:id="musicCheck" text="Muzyka"/>
            </HBox>

            <ChoiceBox fx:id="countryChoice"/>
            <Spinner fx:id="ageSpinner"/>
            <Slider fx:id="ratingSlider" min="0" max="10"/>

            <Button text="Wyślij" onAction="#handleSubmit"/>

            <!-- 🔥 WYNIKI -->
            <VBox spacing="5" styleClass="card" prefWidth="400">
                <Label text="Twoje dane:" styleClass="title"/>

                <Label fx:id="resultName"/>
                <Label fx:id="resultEmail"/>
                <Label fx:id="resultPostal"/>
                <Label fx:id="resultGender"/>
                <Label fx:id="resultHobbies"/>
                <Label fx:id="resultCountry"/>
                <Label fx:id="resultAge"/>
                <Label fx:id="resultRating"/>
            </VBox>

        </VBox>

    </children>
</AnchorPane>